<Window x:Class="UtLoader.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="clr-namespace:UtLoader.ViewModels"
        Title="UtLoader" Height="420" Width="550"
        MinHeight="380" MinWidth="500"
        WindowStartupLocation="CenterScreen"
        Background="#F5F5F5">

    <Window.DataContext>
        <vm:MainViewModel/>
    </Window.DataContext>

    <Grid Margin="15">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <StackPanel Grid.Row="0" Margin="0,0,0,15">
            <TextBlock Text="Video or Playlist URL:" FontWeight="SemiBold" Foreground="#333" Margin="0,0,0,5"/>
            <TextBox Height="28" Text="{Binding Url, UpdateSourceTrigger=PropertyChanged}" 
                     Padding="4" VerticalContentAlignment="Center" FontSize="14"/>
        </StackPanel>

        <StackPanel Grid.Row="1" Orientation="Horizontal" Margin="0,0,0,15">
            <TextBlock Text="Format:" FontWeight="SemiBold" Foreground="#333" VerticalAlignment="Center" Margin="0,0,15,0"/>
            <RadioButton Content="MP3" GroupName="FormatOptions" IsChecked="{Binding IsMp3}" VerticalAlignment="Center"/>
            <RadioButton Content="MP4" GroupName="FormatOptions" IsChecked="{Binding IsMp4}" Margin="15,0,0,0" VerticalAlignment="Center"/>
            <RadioButton Content="Native (Fastest)" GroupName="FormatOptions" IsChecked="{Binding IsNative}" Margin="15,0,0,0" VerticalAlignment="Center"/>
        </StackPanel>

        <Grid Grid.Row="2" Margin="0,0,0,20">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>
            <TextBox Grid.Column="0" Text="{Binding OutputPath}" IsReadOnly="True" 
                     Height="28" Padding="4" VerticalContentAlignment="Center" Background="#EFEFEF"/>
            <Button Grid.Column="1" Content="Browse..." Width="90" Height="28" Margin="10,0,0,0" 
                    Command="{Binding BrowseCommand}" Cursor="Hand"/>
        </Grid>

        <StackPanel Grid.Row="3" Orientation="Horizontal" HorizontalAlignment="Center" Margin="0,0,0,20">
            <Button Content="Download" Command="{Binding DownloadCommand}" Width="120" Height="32" 
                    FontWeight="Bold" Background="#0078D7" Foreground="White" BorderThickness="0" Cursor="Hand"/>
            <Button Content="Stop" Command="{Binding StopCommand}" Width="120" Height="32" Margin="15,0,0,0" 
                    Background="#D13438" Foreground="White" BorderThickness="0" Cursor="Hand"/>
        </StackPanel>

        <Border Grid.Row="4" Background="White" BorderBrush="#DDD" BorderThickness="1" CornerRadius="5" Padding="15">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <ProgressBar Grid.Row="0" Height="18" Maximum="100" Value="{Binding Progress}" Margin="0,0,0,10"/>

                <TextBlock Grid.Row="1" Text="{Binding Status}" FontWeight="Bold" FontSize="14" Foreground="#0078D7" Margin="0,0,0,10"/>

                <StackPanel Grid.Row="2">
                    <TextBlock Text="{Binding FileName, StringFormat='File: {0}'}" 
                               TextTrimming="CharacterEllipsis" ToolTip="{Binding FileName}" 
                               Margin="0,0,0,5" Foreground="#555"/>
                    <StackPanel Orientation="Horizontal">
                        <TextBlock Text="{Binding FileSize, StringFormat='Size: {0}'}" Foreground="#777" Width="150"/>
                        <TextBlock Text="{Binding Format, StringFormat='Format: {0}'}" Foreground="#777"/>
                    </StackPanel>
                </StackPanel>
            </Grid>
        </Border>

        <TextBlock Grid.Row="5" Text="by Murat Khabriev" 
                   HorizontalAlignment="Right" Margin="0,15,0,0" 
                   Opacity="0.5" FontSize="11"/>
    </Grid>
</Window>