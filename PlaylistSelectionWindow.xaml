<Window x:Class="UtLoader.PlaylistSelectionWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Select Playlist Tracks" Height="550" Width="500"
        WindowStartupLocation="CenterOwner"
        Background="#F5F5F5">

    <Grid Margin="15">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <StackPanel Grid.Row="0" Margin="0,0,0,10">
            <TextBlock Text="Choose which tracks to download:" FontWeight="SemiBold" FontSize="14" Foreground="#333" Margin="0,0,0,10"/>
            <CheckBox x:Name="SelectAllCheckBox" Content="Select All / Deselect All" 
                      IsChecked="True" FontWeight="Bold"
                      Checked="SelectAll_Checked" Unchecked="SelectAll_Unchecked"/>
        </StackPanel>

        <Border Grid.Row="1" Background="White" BorderBrush="#DDD" BorderThickness="1" CornerRadius="5" Margin="0,5,0,15">
            <ListBox x:Name="TracksListBox" ItemsSource="{Binding Items}" 
                     BorderThickness="0" Background="Transparent" 
                     ScrollViewer.VerticalScrollBarVisibility="Auto"
                     HorizontalContentAlignment="Stretch">

                <ListBox.ItemTemplate>
                    <DataTemplate>
                        <Border BorderBrush="#EEE" BorderThickness="0,0,0,1" Padding="5,8">
                            <CheckBox IsChecked="{Binding IsSelected}">
                                <TextBlock Text="{Binding Title}" TextWrapping="Wrap" Margin="5,0,0,0"/>
                            </CheckBox>
                        </Border>
                    </DataTemplate>
                </ListBox.ItemTemplate>

            </ListBox>
        </Border>

        <StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Right">
            <Button Content="Cancel" Width="100" Height="32" Margin="0,0,10,0"
                    Background="#EFEFEF" BorderBrush="#CCC" Cursor="Hand"
                    Click="Cancel_Click"/>

            <Button Content="Confirm" Width="100" Height="32"
                    Background="#0078D7" Foreground="White" BorderThickness="0" Cursor="Hand"
                    Click="Confirm_Click"/>
        </StackPanel>
    </Grid>
</Window>